# CodePilot AI - Environment Configuration Example

# Application
APP_NAME="CodePilot AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=codepilot
DB_USERNAME=codepilot
DB_PASSWORD=codepilot

# Redis (Cache & Queue)
REDIS_HOST=redis
REDIS_PASSWORD=codepilot_redis
REDIS_PORT=6379

# Cache
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# GitHub OAuth & App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# AI Providers (Configure at least one)
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4-turbo-preview

# Mail (Mailpit for development)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="dev@codepilot.ai"
MAIL_FROM_NAME="${APP_NAME}"

# Horizon (Queue Monitoring)
HORIZON_PREFIX=codepilot_horizon:

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Sentry (Optional - for production error tracking)
SENTRY_LARAVEL_DSN=

# Analytics (Optional)
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=

# Feature Flags
ENABLE_AI_REVIEW=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
